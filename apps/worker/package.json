{
  "name": "@jamio/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "WRANGLER_WRITE_LOGS=false wrangler deploy --dry-run --env= --outdir dist",
    "build:production": "WRANGLER_WRITE_LOGS=false wrangler deploy --dry-run --env production --outdir dist-production",
    "build:subdomain": "WRANGLER_WRITE_LOGS=false wrangler deploy --dry-run --env subdomain --outdir dist-subdomain",
    "deploy:production": "wrangler deploy --env production",
    "deploy:subdomain": "wrangler deploy --env subdomain",
    "dev": "wrangler dev",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jamio/game-core": "0.1.0",
    "@jamio/protocol": "0.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260707.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.24.3"
  }
}
